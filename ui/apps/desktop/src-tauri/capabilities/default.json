{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capabilities for APXV desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "store:default",
    "core:tray:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:8741/**" },
        { "url": "http://localhost:8741/**" }
      ]
    }
  ]
}